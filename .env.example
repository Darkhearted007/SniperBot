# =============================================================================
# SniperBot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Paper trading mode (default) works out of the box with just DASHBOARD_SECRET_KEY.
# Live mode requires several Solana-specific variables.
#
# Usage:
#   export $(grep -v '^\s*#' .env | xargs) && npm start
#   # or inline:  DASHBOARD_SECRET_KEY=mykey npm start
# =============================================================================

# ── Mode & General ───────────────────────────────────────────────────────────

# Trading mode: "paper" (default, safe simulator) or "live" (real on-chain swaps)
# TRADING_MODE=paper

# HTTP port for the dashboard web UI and API server
# Default: 3000
# PORT=3000


# ── Dashboard Authentication ─────────────────────────────────────────────────
# At least ONE auth method must be configured to access the dashboard UI:
#   1) Secret key, or
#   2) Solana wallet challenge/session

# Secret key for dashboard access.
# Set this and send it as the 'x-secret-key' header from the dashboard UI.
# Required for paper mode to access the dashboard. Also works in live mode.
# DASHBOARD_SECRET_KEY=change-me-to-something-secret

# Comma-separated Solana wallet addresses allowed to sign in to the dashboard.
# Used for wallet-challenge auth flow. Optional — only needed for wallet sign-in.
# DASHBOARD_ALLOWED_WALLETS=WalletAddress1,WalletAddress2

# Wallet sign-in challenge lifetime in milliseconds.
# Default: 300000 (5 minutes)
# DASHBOARD_CHALLENGE_TTL_MS=300000

# Wallet session lifetime in milliseconds.
# Default: 43200000 (12 hours)
# DASHBOARD_SESSION_TTL_MS=43200000


# ── Paper Trading (default mode) ──────────────────────────────────────────────

# Delay between paper-trading simulation cycles in milliseconds.
# Default: 0 (runs as fast as possible)
# PAPER_CYCLE_DELAY_MS=0

# If true, paper mode automatically stops when the goal (2.0 SOL) is reached
# or the time limit (24h) expires. Default: false (runs indefinitely).
# PAPER_AUTO_STOP_ON_GOAL=false


# ── Bot State Persistence ────────────────────────────────────────────────────

# File path for persisting learning/trade state across restarts.
# If set, the bot saves its state to this file periodically and restores it on restart.
# BOT_STATE_FILE=./sniperbot-state.json

# How often (in cycles) to persist state to disk. Default: 10
# BOT_STATE_PERSIST_EVERY_CYCLES=10


# =============================================================================
# LIVE TRADING CONFIGURATION
# =============================================================================
# ⚠ WARNING: Live mode sends real on-chain swaps from your wallet.
# Use a dedicated test wallet with a very small SOL balance first.
# Only set TRADING_MODE=live when you are ready to trade real assets.
#
# See the full README for detailed guidance before enabling live mode.
# =============================================================================

# ── Live Mode — Required ─────────────────────────────────────────────────────

# Solana RPC HTTPS endpoint (e.g., from Helius, Triton, QuickNode, or public RPC)
# SOLANA_RPC_URL=https://your-rpc-endpoint.example.com

# Wallet secret key as a 64-byte JSON array or base64-encoded 64-byte keypair.
# Example: '[12,34,56,78,90,...]' (all 64 numbers)
# SOLANA_WALLET_SECRET=[12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56]

# JSON array of tokens to monitor directly.
# Each item requires: symbol, outputMint, decimals (0-18).
# Recommended fields: liquidityUsd, rugScore.
# Example:
# SOLANA_WATCHLIST_JSON='[
#   {
#     "symbol": "BONK",
#     "tokenName": "Bonk",
#     "outputMint": "DezXAZ8z7PnrnRJjz3wXBoRgixCa6Yo81Bp1PB263yPB263",
#     "decimals": 5,
#     "liquidityUsd": 1000000,
#     "rugScore": 0.15
#   }
# ]'


# ── Live Mode — Optional Timing & Sizing ─────────────────────────────────────

# Poll interval in milliseconds for the live trading loop. Default: 15000 (15s)
# LIVE_POLL_INTERVAL_MS=15000

# Slippage tolerance in basis points (bps). Default: 100 (1%)
# LIVE_SLIPPAGE_BPS=100

# Minimum SOL reserve to keep in wallet (never trade this). Default: 0.02 SOL
# LIVE_MIN_SOL_RESERVE=0.02

# Optional maximum bankroll cap in SOL for strategy position sizing.
# If not set, the full balance (minus reserve) is usable.
# LIVE_MAX_BANKROLL_SOL=0.25


# ── Live Mode — Automatic Watchlist ──────────────────────────────────────────

# JSON array of candidate tokens for automatic watchlist selection.
# Same format as SOLANA_WATCHLIST_JSON. The bot ranks and selects the top N.
# SOLANA_AUTO_WATCHLIST_JSON='[{"symbol":"MYCOIN","outputMint":"...","decimals":6}]'

# Number of top candidates to keep in the active watchlist (positive integer).
# Defaults to the length of SOLANA_AUTO_WATCHLIST_JSON or POOL_DISCOVERY_MAX_CANDIDATES.
# LIVE_AUTO_WATCHLIST_SIZE=5


# ── Live Mode — Supervision & Safety ─────────────────────────────────────────

# Require manual approval before executing entries and exits (supervised mode).
# When enabled, trade decisions are queued for operator approval via the dashboard.
# Default: false
# LIVE_REQUIRE_SUPERVISION=false

# Enable on-chain safety pipeline (mint authority, freeze authority, holder
# concentration, LP lock/burn, honeypot checks) for every live entry.
# This replaces trust in hand-typed rugScore with real chain checks.
# Default: false
# LIVE_REQUIRE_ONCHAIN_SAFETY=false

# How long (ms) to cache on-chain safety results per mint. Default: 60000 (1 min)
# SAFETY_CACHE_TTL_MS=60000


# ── Jupiter API (overrides) ──────────────────────────────────────────────────

# Jupiter quote API base URL. Override for custom/compatible endpoints.
# Default: https://quote-api.jup.ag/v6
# JUPITER_QUOTE_API_BASE=https://quote-api.jup.ag/v6

# Jupiter swap API base URL.
# Default: https://quote-api.jup.ag/v6
# JUPITER_SWAP_API_BASE=https://quote-api.jup.ag/v6


# ── Real-Time Pool Discovery ─────────────────────────────────────────────────

# Enable real-time new pool/pair discovery via Solana WebSocket.
# Watches Raydium and Pump.fun program logs for new token creation.
# Default: false
# LIVE_POOL_DISCOVERY=false

# Solana WebSocket RPC endpoint. Required when LIVE_POOL_DISCOVERY=true.
# SOLANA_WS_URL=wss://your-rpc-endpoint.example.com

# Comma-separated program IDs to watch for new pool creation.
# Defaults: Raydium AMM v4, Raydium CPMM, Pump.fun
# POOL_DISCOVERY_PROGRAMS=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8,CPMMoo8L3F4NbTegBCKVNunggL7H1ZpdTHKxQB5qKP1C,6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# Rolling cap on discovered candidates kept in memory. Default: 25
# POOL_DISCOVERY_MAX_CANDIDATES=25


# =============================================================================
# EXAMPLE: Minimal paper-mode startup (quick preview)
# =============================================================================
# Copy the line below and run it:
#   DASHBOARD_SECRET_KEY=preview npm start
#
# Then open http://localhost:3000 in your browser.
# Enter "http://localhost:3000" as the Server URL and "preview" as the Secret Key.
